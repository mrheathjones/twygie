rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Family tree data — owner + allowed readers ────────────────
    // Owner has full access; managed account UIDs can read only
    match /familyTrees/{userId} {
      allow read: if request.auth != null &&
        (request.auth.uid == userId ||
         (resource.data.keys().hasAny(['allowedReaders']) &&
          request.auth.uid in resource.data.allowedReaders));
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── User settings — owner only ──────────────────────────────────
    // Preferences, theme, toggles — private per user
    match /userSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── User profiles — owner only ───────────────────────────────────
    // Username, display name, email — each user manages their own
    match /userProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Usernames — uniqueness enforcer ──────────────────────────────
    // Anyone can read (availability check), only owner can create/delete
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
    }

    // ─── Managed accounts — any auth can read (PIN login), parent writes ─
    match /managedAccounts/{accountId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.parentUid;
    }

    // ─── Managed account lookup by username (for PIN login) ──────────
    // Allows querying managedAccounts where username matches
    // (covered by the read rule above via list queries)

    // ─── Leafs — family stories/memories — owner only ───────────────
    match /leafs/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── Tree links — both participants can access ───────────────────
    // (Phase 3 — not yet in use, but rules ready)
    match /treeLinks/{linkId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.userA ||
         request.auth.uid == resource.data.userB);
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.uid == resource.data.userA ||
         request.auth.uid == resource.data.userB);
    }

    // ─── Link invites — creator and redeemer ─────────────────────────
    // (Phase 3 — not yet in use, but rules ready)
    match /linkInvites/{code} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.createdBy ||
         resource.data.usedBy == null);
      allow delete: if request.auth != null &&
        request.auth.uid == resource.data.createdBy;
    }

    // ─── Deny everything else ────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
